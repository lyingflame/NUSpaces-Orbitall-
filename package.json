{
  "name": "nuspaces",
  "version": "1.0.0",
  "description": "A study spot recommendation web app for NUS students",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "npm run dev --prefix client",
    "server": "npm run dev --prefix server",
    "client-install": "npm install --prefix client",
    "server-install": "npm install --prefix server",
    "install-all": "npm run client-install && npm run server-install",
    "db:migrate": "node server/scripts/runMigrations.js",
    "db:seed": "node server/scripts/seedData.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lyingflame/NUSpaces-Orbitall-.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/lyingflame/NUSpaces-Orbitall-/issues"
  },
  "homepage": "https://github.com/lyingflame/NUSpaces-Orbitall-#readme",
  "dependencies": {
    "concurrently": "^10.0.0"
  }
}
